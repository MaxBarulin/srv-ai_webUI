APP_HOST=0.0.0.0
APP_PORT=8080
DATA_DIR=./data
LLM_BASE_URL=http://127.0.0.1:8000/v1
# API-ключ LLM-сервера (опционально). Нужен, если llama.cpp запущен с --api-key
# или подключён сторонний OpenAI-совместимый провайдер. Если сервер ключ не
# требует — переменную можно оставить пустой ИЛИ заполненной: лишний ключ
# не мешает (сервер без аутентификации игнорирует заголовок).
LLM_API_KEY=
LLM_MODEL=qwen3.6-35b
LLM_TIMEOUT=600
# Размер контекста модели (n_ctx llama.cpp) — для показа «заполнение контекста N%»
# в чате. 0 — неизвестен, процент не показывается. При старте UI опрашивает
# /props самого сервера и, если сервер отдал n_ctx (это делает llama.cpp) —
# использует его значение вместо этой переменной. Значение здесь — запасное
# на случай, когда /props недоступен (например, у стороннего провайдера).
LLM_CONTEXT_SIZE=32768
RAG_ENABLED=true
RAG_BASE_URL=http://<машина-с-lightrag>:9621
# API-ключ LightRAG (опционально, аналогично LLM_API_KEY)
RAG_API_KEY=
RAG_MODE=hybrid
SESSION_TTL_HOURS=12
TOOLS_CONFIRM_DESTRUCTIVE=true
SYSTEM_PROMPT_FILE=./system_prompt.txt
MAX_UPLOAD_MB=15
# PDF в режиме «картинка»: сколько страниц отправлять модели. 0 — ВСЕ страницы
# (каждая — отдельная полная картинка). Положительное число — предохранитель
# от переполнения контекста (каждая страница = сотни-тысячи токенов).
VISION_MAX_PAGES=0
PII_FILTER=false
PII_WHITELIST_FILE=./pii_whitelist.txt
# Шифрование БД на диске (SQLCipher, AES-256). Пусто — БД не шифруется.
# Требует пакет sqlcipher3-binary. ВНИМАНИЕ: включать только на НОВОЙ базе
# (существующую надо мигрировать вручную), потеря ключа = потеря данных.
DB_KEY=
# Хранение истории чатов: сообщения старше N дней удаляются автоматически
# (при старте и раз в сутки). 0 — хранить вечно.
CHAT_RETENTION_DAYS=0
